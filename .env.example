# Copy to .env.local and fill in. All of these are also set in Vercel project envs.

# Resend: full-access API key (sending + contacts). resend.com/api-keys
RESEND_API_KEY=
# Resend segment that newsletter signups are added to ("El Boletin")
RESEND_SEGMENT_ID=

# Neon Postgres (pooled for the app, unpooled for migrations/scripts)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Canonical site URL used in email links
SITE_URL=https://colombiancentral.com
# Random hex string used to sign unsubscribe links (openssl rand -hex 32)
UNSUBSCRIBE_SECRET=
