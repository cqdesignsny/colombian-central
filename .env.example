# Copy to .env.local and fill in. All of these are also set in Vercel project envs.

# Resend: full-access API key (sending + contacts). resend.com/api-keys
RESEND_API_KEY=
# Resend segment that newsletter signups are added to ("El Boletin")
RESEND_SEGMENT_ID=

# Neon Postgres (pooled for the app, unpooled for migrations/scripts)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Canonical site URL used in email links and Stripe redirect URLs
SITE_URL=https://colombiancentral.com
# Random hex string used to sign unsubscribe links (openssl rand -hex 32)
UNSUBSCRIBE_SECRET=

# Stripe (CQM account). Until these are set, checkout falls back to email orders.
# Secret key: sk_test_... while testing, sk_live_... once the account is activated.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) for the /api/stripe/webhook endpoint.
STRIPE_WEBHOOK_SECRET=
# Set to "true" to switch the cart copy to card checkout (after the keys are live).
NEXT_PUBLIC_STRIPE_ENABLED=

# Vercel cron secret, sent as a Bearer token to the abandoned-cart + El Paisa jobs.
CRON_SECRET=

# Vercel AI Gateway key that powers El Paisa (chat + reporter).
# Create at vercel.com dashboard -> AI Gateway -> API keys.
AI_GATEWAY_API_KEY=

# Upstash Redis (serverless) for rate limiting at scale. Optional: when unset,
# the limiter falls back to the Neon DB. Add via Vercel Marketplace -> Upstash;
# it injects both vars automatically. (Vercel KV is retired; Upstash is the path.)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
